<Page x:Class="Client.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Width="300" VerticalAlignment="Center">
        <TextBlock Text="Вход в систему" FontSize="26" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,30"/>
        
        <TextBlock Text="Логин"/>
        <TextBox x:Name="LoginBox" Text="admin" Margin="0,0,0,15" Padding="8" FontSize="14"/>
        
        <TextBlock Text="Пароль"/>
        <PasswordBox x:Name="PassBox" Password="123" Margin="0,0,0,25" Padding="8" FontSize="14"/>
        
        <Button Content="ВОЙТИ" Background="#0078D7" Foreground="White" Padding="10" FontSize="16" Click="LoginBtn_Click"/>
        <TextBlock x:Name="ErrorText" Foreground="Red" TextAlignment="Center" Margin="0,15,0,0"/>
    </StackPanel>
</Page>