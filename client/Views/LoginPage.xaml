<Page x:Class="Client.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource PanelBrush}" Width="300" VerticalAlignment="Center" Padding="30" CornerRadius="10">
        <StackPanel>
            <TextBlock Text="Вход в систему" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" TextAlignment="Center" Margin="0,0,0,20"/>
            
            <TextBlock Text="Логин" Foreground="{DynamicResource HintTextBrush}"/>
            <TextBox x:Name="LoginBox" Text="admin" Margin="0,0,0,15" Padding="8"/>
            
            <TextBlock Text="Пароль" Foreground="{DynamicResource HintTextBrush}"/>
            <PasswordBox x:Name="PassBox" Password="123" Margin="0,0,0,25" Padding="8"/>
            
            <Button Content="ВОЙТИ" Background="#0078D7" Foreground="White" Padding="10" FontSize="16" Click="LoginBtn_Click"/>
            
            <!-- Кнопка перехода к регистрации -->
            <Button Content="Нет аккаунта? Зарегистрироваться" Background="Transparent" Foreground="{DynamicResource HintTextBrush}" BorderThickness="0" Margin="0,15,0,0" Click="GoToRegister_Click"/>
            
            <TextBlock x:Name="ErrorText" Foreground="Red" TextAlignment="Center" Margin="0,10,0,0"/>
        </StackPanel>
    </Border>
</Page>