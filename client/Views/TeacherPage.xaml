<Page x:Class="Client.Views.TeacherPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель (Сайдбар) -->
        <Border Background="{DynamicResource PanelBrush}" Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="10">
                <TextBlock x:Name="TeacherNameTxt" Foreground="{DynamicResource TextBrush}" FontSize="16" FontWeight="Bold" Margin="0,20,0,30" TextWrapping="Wrap"/>
                <Button Content="📝 Создать тест" Background="#007ACC" Foreground="White" Padding="10" Margin="0,0,0,10" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- Правая панель (Рабочая область с прокруткой) -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="30">
                <Button Content="Выйти из аккаунта" Background="#DC3545" Foreground="White" Padding="10,5" HorizontalAlignment="Right" VerticalAlignment="Top" Click="Logout_Click"/>

                <StackPanel Margin="0,40,0,20">
                    <TextBlock Text="Конструктор теста" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Название теста" Foreground="{DynamicResource HintTextBrush}"/>
                    <TextBox x:Name="TestTitle" FontSize="16" Padding="8" Margin="0,5,0,15" Background="Transparent" Foreground="{DynamicResource TextBrush}"/>
                    
                    <TextBlock Text="Описание теста" Foreground="{DynamicResource HintTextBrush}"/>
                    <TextBox x:Name="TestDesc" FontSize="14" Padding="8" Height="60" TextWrapping="Wrap" Margin="0,5,0,25" Background="Transparent" Foreground="{DynamicResource TextBrush}"/>

                    <!-- СПИСОК ВОПРОСОВ (Динамический) -->
                    <ItemsControl x:Name="QuestionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Текст вопроса:" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" FontSize="16" Padding="5" Margin="0,0,0,10" Background="Transparent" Foreground="{DynamicResource TextBrush}"/>

                                        <TextBlock Text="Варианты ответа (отметьте правильный):" Foreground="{DynamicResource HintTextBrush}" Margin="0,10,0,5"/>
                                        
                                        <!-- СПИСОК ВАРИАНТОВ ОТВЕТА -->
                                        <ItemsControl ItemsSource="{Binding Options}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,5,0,5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <RadioButton IsChecked="{Binding IsCorrect, Mode=TwoWay}" GroupName="{Binding DataContext.GroupId, RelativeSource={RelativeSource AncestorType=Border}}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <TextBox Grid.Column="1" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Padding="5" Background="Transparent" Foreground="{DynamicResource TextBrush}"/>
                                                        <Button Grid.Column="2" Content="❌" Background="Transparent" Foreground="Red" BorderThickness="0" Margin="5,0,0,0" Click="RemoveOption_Click" Tag="{Binding}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                            <Button Content="+ Добавить вариант" Background="Transparent" Foreground="#007ACC" BorderThickness="0" Click="AddOption_Click" Tag="{Binding}"/>
                                            <Button Content="Удалить вопрос" Background="Transparent" Foreground="Red" BorderThickness="0" Margin="20,0,0,0" Click="RemoveQuestion_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Кнопки управления тестом -->
                    <Button Content="+ ДОБАВИТЬ ВОПРОС" Background="Transparent" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="10" Margin="0,10,0,30" Click="AddQuestion_Click"/>
                    
                    <Button Content="💾 СОХРАНИТЬ ТЕСТ НА СЕРВЕРЕ" Height="45" Background="#28A745" Foreground="White" FontSize="16" FontWeight="Bold" Click="SaveTest_Click"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>