<Page x:Class="Client.Views.TeacherPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgBrush}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>    
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,2" Padding="0,0,0,10" Margin="0,0,0,20">
            <Grid>
                <!-- Имя препода и кнопка темы теперь рядом! -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="TeacherNameTxt" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                    <Button x:Name="ThemeToggleBtn" Content="🌙 Темная" Margin="20,0,0,0" Padding="10,5" Background="{DynamicResource PanelBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" Click="ToggleTheme_Click"/>
                </StackPanel>
                
                <Button Content="Выйти" Background="#6C757D" Foreground="White" Padding="15,5" HorizontalAlignment="Right" VerticalAlignment="Center" Click="Logout_Click" BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- 1. ГЛАВНАЯ ПАНЕЛЬ ПРЕПОДАВАТЕЛЯ -->
        <Grid x:Name="MainPanelGrid" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Панель преподавателя" FontSize="24" FontWeight="Bold" Foreground="#4285F4" HorizontalAlignment="Center" Margin="0,0,0,30"/>
            
            <Grid Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Созданные тесты:" FontSize="18" FontWeight="Bold" Foreground="#4285F4" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <Button Content="+ Создать тест" Background="#4285F4" Foreground="White" Padding="15,8" HorizontalAlignment="Right" VerticalAlignment="Center" Click="ShowCreateTest_Click" BorderThickness="0"/>
            </Grid>

            <TextBlock Grid.Row="2" x:Name="NoTestsTxt" Text="У вас пока нет созданных тестов. Нажмите '+ Создать тест', чтобы начать." FontSize="16" Foreground="{DynamicResource HintTextBrush}" HorizontalAlignment="Center" Margin="0,30,0,0" Visibility="Collapsed"/>

            <ListBox Grid.Row="2" x:Name="CreatedTestsList" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,10">
                            <Grid>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="14" Foreground="{DynamicResource HintTextBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Выдать доступ" Background="#28A745" Foreground="White" Padding="10,5" Margin="0,0,10,0" BorderThickness="0" Tag="{Binding Id}" Click="ShowGiveAccess_Click"/>
                                    <Button Content="Статистика" Background="#17A2B8" Foreground="White" Padding="10,5" BorderThickness="0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- 2. ПАНЕЛЬ СОЗДАНИЯ ТЕСТА -->
        <Grid x:Name="CreateTestGrid" Grid.Row="1" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Button Grid.Row="0" Content="← Назад" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent" Foreground="#4285F4" BorderThickness="0" Click="BackToMain_Click" Margin="0,0,0,15"/>
            
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Конструктор теста" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Название теста" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,5"/>
                    <TextBox x:Name="TestTitle" FontSize="16" Padding="8" Margin="0,0,0,15" Background="Transparent" Foreground="{DynamicResource TextBrush}"/>
                    
                    <TextBlock Text="Описание теста" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,5"/>
                    <TextBox x:Name="TestDesc" FontSize="14" Padding="8" Height="60" TextWrapping="Wrap" Margin="0,0,0,25" Background="Transparent" Foreground="{DynamicResource TextBrush}"/>

                    <ItemsControl x:Name="QuestionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource PanelBrush}" CornerRadius="5" Padding="15" Margin="0,0,0,15" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Вопрос:" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" FontSize="16" Padding="5" Margin="0,0,0,15" Background="Transparent" Foreground="{DynamicResource TextBrush}"/>
                                        
                                        <TextBlock Text="Варианты ответа (отметьте правильный):" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,5"/>
                                        <ItemsControl ItemsSource="{Binding Options}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,5,0,5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <RadioButton IsChecked="{Binding IsCorrect, Mode=TwoWay}" GroupName="{Binding DataContext.GroupId, RelativeSource={RelativeSource AncestorType=Border}}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <TextBox Grid.Column="1" Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Padding="5" Background="Transparent" Foreground="{DynamicResource TextBrush}"/>
                                                        <Button Grid.Column="2" Content="❌" Background="Transparent" Foreground="Red" BorderThickness="0" Margin="5,0,0,0" Click="RemoveOption_Click" Tag="{Binding}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                            <Button Content="+ Вариант" Background="Transparent" Foreground="#4285F4" BorderThickness="0" Click="AddOption_Click" Tag="{Binding}"/>
                                            <Button Content="Удалить вопрос" Background="Transparent" Foreground="Red" BorderThickness="0" Margin="15,0,0,0" Click="RemoveQuestion_Click" Tag="{Binding}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="+ ДОБАВИТЬ ВОПРОС" Background="Transparent" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" Padding="10" Margin="0,10,0,20" Click="AddQuestion_Click"/>
                    <Button Content="СОХРАНИТЬ ТЕСТ" Height="45" Background="#28A745" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Click="SaveTest_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 3. ПАНЕЛЬ ВЫДАЧИ ДОСТУПА -->
        <Grid x:Name="GiveAccessGrid" Grid.Row="1" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Content="← Назад" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent" Foreground="#4285F4" BorderThickness="0" Click="BackToMain_Click" Margin="0,0,0,15"/>
            
            <StackPanel Grid.Row="1">
                <TextBlock Text="Выдать доступ к тесту" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,10"/>
                <TextBlock Text="Выберите студентов, которые смогут пройти этот тест:" FontSize="14" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,20"/>
                
                <Border Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="10" Height="250">
                    <ScrollViewer>
                        <ItemsControl x:Name="StudentsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding FullName}" IsChecked="{Binding IsChecked, Mode=TwoWay}" Foreground="{DynamicResource TextBrush}" FontSize="16" Margin="5"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
                <Button Content="СОХРАНИТЬ ДОСТУПЫ" Height="45" Background="#28A745" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0" Margin="0,20,0,0" Click="SaveAccess_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>