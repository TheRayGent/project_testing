<Page x:Class="Client.Views.TeacherPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="TeacherPage">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель -->
        <Border Background="#2B2B2B" Grid.Column="0">
            <StackPanel Margin="10">
                <TextBlock x:Name="TeacherNameTxt" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,20,0,30" TextWrapping="Wrap"/>
                <Button Content="Создать тест" Background="#3F3F46" Foreground="White" Padding="10" Margin="0,0,0,10" BorderThickness="0"/>
            </StackPanel>
        </Border>

        <!-- Правая панель -->
        <Grid Grid.Column="1" Margin="30">
            <Button Content="Выйти из аккаунта" Background="#DC3545" Foreground="White" Padding="10,5" HorizontalAlignment="Right" VerticalAlignment="Top" Click="Logout_Click"/>
            
            <StackPanel Margin="0,40,0,0">
                <TextBlock Text="Новый тест" FontSize="28" FontWeight="Bold" Margin="0,0,0,20"/>
                <TextBox x:Name="TestTitle" Text="Название теста..." FontSize="16" Padding="5" Margin="0,0,0,10"/>
                <TextBox x:Name="TestDesc" Text="Описание..." FontSize="14" Padding="5" Height="60" TextWrapping="Wrap" Margin="0,0,0,20"/>
                <Button Content="Сохранить тест на сервере" Width="250" HorizontalAlignment="Left" Background="#28A745" Foreground="White" Padding="10" Click="SaveTest_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>