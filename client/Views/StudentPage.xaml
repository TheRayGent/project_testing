<Page x:Class="Client.Views.StudentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="40">
        <TextBlock x:Name="StudentNameTxt" FontSize="18" Foreground="Gray" Margin="0,0,0,20"/>
        <Button Content="Выйти из аккаунта" Background="Red" Foreground="White" Padding="5" Click="Logout_Click" HorizontalAlignment="Right"/>
        <Border Background="#F3F4F6" Padding="20" CornerRadius="10">
            <StackPanel>
                <TextBlock x:Name="QuestionTxt" FontSize="22" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,20"/>
                
                <!-- ВОТ ЗДЕСЬ МАГИЯ: Автоматическая генерация RadioButton (кнопок) -->
                <ItemsControl x:Name="DynamicOptionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- {Binding} берет текст из массива Options -->
                            <RadioButton Content="{Binding}" GroupName="Answers" FontSize="18" Margin="0,5,0,10"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Button Content="Следующий вопрос" Width="200" HorizontalAlignment="Right" Background="#0078D7" Foreground="White" Padding="12" Margin="0,20,0,0"/>
    </StackPanel>
</Page>