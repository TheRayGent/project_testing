<Page x:Class="Client.Views.StudentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgBrush}">
    
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>    
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,2" Padding="0,0,0,10" Margin="0,0,0,20">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StudentNameTxt" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                    <Button x:Name="ThemeToggleBtn" Content="🌙 Темная" Margin="20,0,0,0" Padding="10,5" Background="{DynamicResource PanelBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" Click="ToggleTheme_Click"/>
                </StackPanel>
                <Button Content="Выйти" Background="#DC3545" Foreground="White" Padding="15,5" HorizontalAlignment="Right" VerticalAlignment="Center" Click="Logout_Click" BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- ЭКРАН 1: СПИСОК ТЕСТОВ -->
        <Grid x:Name="TestSelectionGrid" Grid.Row="1">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Доступные тесты" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,15"/>
            <TextBlock Grid.Row="1" x:Name="NoTestsTxt" Text="У вас пока нет доступных тестов." FontSize="16" Foreground="{DynamicResource HintTextBrush}" Margin="0,30,0,0" Visibility="Collapsed"/>
            
            <ListBox Grid.Row="2" x:Name="TestsListBox" Margin="0,20,0,0" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="14" Foreground="{DynamicResource HintTextBrush}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </StackPanel>
                                
                                <!-- ИСПРАВЛЕНИЕ: Кнопка "Начать тест" будет полностью пропадать, если тест пройден -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ResultText}" FontSize="16" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Right" Margin="0,0,0,5"/>
                                    
                                    <!-- Visibility привязана к свойству ButtonVisibility из модели -->
                                    <Button Content="Начать тест" Visibility="{Binding ButtonVisibility}" Background="#007ACC" Foreground="White" Padding="15,10" BorderThickness="0" Tag="{Binding Id}" Click="StartTest_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- ЭКРАН 2: ПРОХОЖДЕНИЕ ТЕСТА -->
        <Grid x:Name="TestPassingGrid" Grid.Row="1" Visibility="Collapsed">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <TextBlock Grid.Row="0" x:Name="ProgressTxt" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,10"/>
            
            <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" Padding="20" CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,10,0,20" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock x:Name="QuestionTxt" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>
                    <ItemsControl x:Name="DynamicOptionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Content="{Binding Text}" IsChecked="{Binding IsSelected, Mode=TwoWay}" GroupName="StudentAnswers" Foreground="{DynamicResource TextBrush}" FontSize="18" Margin="0,5,0,10"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Button Grid.Row="2" x:Name="NextQuestionBtn" Content="Следующий вопрос" Width="200" HorizontalAlignment="Right" Background="#28A745" Foreground="White" Padding="12" BorderThickness="0" Click="NextQuestion_Click"/>
        </Grid>
    </Grid>
</Page>