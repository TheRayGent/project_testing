<Page x:Class="Client.Views.StudentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="30">
        <Button Content="Выйти" Background="#DC3545" Foreground="White" Padding="10,5" HorizontalAlignment="Right" VerticalAlignment="Top" Click="Logout_Click"/>
        <TextBlock x:Name="StudentNameTxt" FontSize="18" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,20" VerticalAlignment="Top"/>

        <!-- ЭКРАН 1: СПИСОК ТЕСТОВ -->
        <Grid x:Name="TestSelectionGrid" Margin="0,40,0,0">
            <TextBlock Text="Доступные тесты" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,15"/>
            
            <ListBox x:Name="TestsListBox" Margin="0,40,0,0" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource PanelBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="14" Foreground="{DynamicResource HintTextBrush}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Начать тест" Background="#007ACC" Foreground="White" Padding="15,10" Tag="{Binding Id}" Click="StartTest_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- ЭКРАН 2: ПРОХОЖДЕНИЕ ТЕСТА -->
        <Grid x:Name="TestPassingGrid" Visibility="Collapsed" Margin="0,40,0,0">
            <TextBlock x:Name="ProgressTxt" FontSize="16" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,10"/>
            
            <Border Background="{DynamicResource PanelBrush}" Padding="20" CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,30,0,0" VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock x:Name="QuestionTxt" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>
                    
                    <ItemsControl x:Name="DynamicOptionsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Content="{Binding Text}" IsChecked="{Binding IsSelected, Mode=TwoWay}" GroupName="StudentAnswers" Foreground="{DynamicResource TextBrush}" FontSize="18" Margin="0,5,0,10"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Button x:Name="NextQuestionBtn" Content="Следующий вопрос" Width="200" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="#28A745" Foreground="White" Padding="12" Click="NextQuestion_Click"/>
        </Grid>
    </Grid>
</Page>