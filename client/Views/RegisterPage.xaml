<Page x:Class="Client.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource PanelBrush}" Width="350" VerticalAlignment="Center" Padding="30" CornerRadius="10">
        <StackPanel>
            <TextBlock Text="Регистрация" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" TextAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Имя" Foreground="{DynamicResource HintTextBrush}"/>
            <TextBox x:Name="FNameBox" Margin="0,0,0,10" Padding="8"/>

            <TextBlock Text="Фамилия" Foreground="{DynamicResource HintTextBrush}"/>
            <TextBox x:Name="LNameBox" Margin="0,0,0,10" Padding="8"/>

            <!-- НОВОЕ: Поле Группа -->
            <TextBlock Text="Группа (Для студентов)" Foreground="{DynamicResource HintTextBrush}"/>
            <TextBox x:Name="GroupBox" Margin="0,0,0,10" Padding="8" Text="БФУ-1"/>

            <TextBlock Text="Логин" Foreground="{DynamicResource HintTextBrush}"/>
            <TextBox x:Name="LoginBox" Margin="0,0,0,10" Padding="8"/>

            <TextBlock Text="Пароль" Foreground="{DynamicResource HintTextBrush}"/>
            <PasswordBox x:Name="PassBox" Margin="0,0,0,15" Padding="8"/>

            <TextBlock Text="Кто вы?" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,5"/>
            <ComboBox x:Name="RoleBox" SelectedIndex="1" Margin="0,0,0,25" Padding="5">
                <ComboBoxItem Content="Преподаватель" Tag="teacher"/>
                <ComboBoxItem Content="Студент" Tag="student"/>
            </ComboBox>

            <Button Content="Создать аккаунт" Background="#28A745" Foreground="White" Padding="10" FontSize="16" Click="RegisterBtn_Click"/>
            
            <Button Content="Назад ко входу" Background="Transparent" Foreground="#0078D7" BorderThickness="0" Margin="0,15,0,0" Click="BackToLogin_Click"/>
            <TextBlock x:Name="ErrorText" Foreground="Red" TextAlignment="Center" Margin="0,10,0,0"/>
        </StackPanel>
    </Border>
</Page>