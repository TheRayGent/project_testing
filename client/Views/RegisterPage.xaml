<Page x:Class="Client.Views.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BgBrush}"> <!-- Добавлен фон, чтобы страница не была белой -->
    
    <Border Background="{DynamicResource PanelBrush}" Width="350" VerticalAlignment="Center" Padding="30" CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Регистрация" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextBrush}" TextAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Имя" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="FNameBox" Margin="0,0,0,10" Padding="8" Background="Transparent" Foreground="{DynamicResource TextBrush}"/>

            <TextBlock Text="Фамилия" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="LNameBox" Margin="0,0,0,10" Padding="8" Background="Transparent" Foreground="{DynamicResource TextBrush}"/>

            <TextBlock Text="Кто вы?" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,5"/>
            <!-- ИСПРАВЛЕНИЕ: Добавлено событие SelectionChanged для скрытия/показа поля группы -->
            <ComboBox x:Name="RoleBox" SelectedIndex="1" Margin="0,0,0,15" Padding="5" SelectionChanged="RoleBox_SelectionChanged">
                <ComboBoxItem Content="Преподаватель" Tag="teacher"/>
                <ComboBoxItem Content="Студент" Tag="student"/>
            </ComboBox>

            <!-- ИСПРАВЛЕНИЕ: Заменили TextBox на ComboBox для выбора группы -->
            <StackPanel x:Name="GroupPanel">
                <TextBlock Text="Выберите вашу группу:" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,5"/>
                <ComboBox x:Name="GroupBox" Margin="0,0,0,15" Padding="5"/>
            </StackPanel>

            <TextBlock Text="Логин" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="LoginBox" Margin="0,0,0,10" Padding="8" Background="Transparent" Foreground="{DynamicResource TextBrush}"/>

            <TextBlock Text="Пароль" Foreground="{DynamicResource HintTextBrush}" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PassBox" Margin="0,0,0,25" Padding="8" Background="Transparent" Foreground="{DynamicResource TextBrush}"/>

            <Button Content="Создать аккаунт" Background="#28A745" Foreground="White" Padding="10" FontSize="16" Click="RegisterBtn_Click" BorderThickness="0"/>
            
            <Button Content="Назад ко входу" Background="Transparent" Foreground="#4285F4" BorderThickness="0" Margin="0,15,0,0" Click="BackToLogin_Click"/>
            
            <TextBlock x:Name="ErrorText" Foreground="Red" TextAlignment="Center" Margin="0,10,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</Page>